    {
      "name": "Numbers",
      "short_name": "123",
      "url": "/?page=numbers",
      "icon": "https://kids-learn-fun-time.vercel.app/icon-192.png"
    }
  ],
  "generatorApp": "bubblewrap-cli",
  "webManifestUrl": "https://kids-learn-fun-time.vercel.app/manifest.webmanifest",
